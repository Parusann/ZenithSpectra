# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/zenithspectra

# LLM Provider: "ollama" (local dev) or "groq" (production)
LLM_PROVIDER=ollama
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1:8b

# CORS
CORS_ORIGINS=http://localhost:3000

# Ingestion
INGESTION_INTERVAL_HOURS=6

# Debug
DEBUG=true
