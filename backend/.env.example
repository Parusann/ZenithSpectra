# Database (async PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/zenithspectra

# LLM Provider: "ollama" for local dev, "groq" for production
LLM_PROVIDER=ollama
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=gemma4:31b

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Ingestion schedule (hours between RSS pulls)
INGESTION_INTERVAL_HOURS=6

# Enable LLM-powered enrichment (summaries, classification, credibility)
ENABLE_LLM_ENRICHMENT=false

# Server
HOST=0.0.0.0
PORT=8000

# Debug mode
DEBUG=false
