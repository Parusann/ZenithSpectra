# Database (async PostgreSQL) — driver MUST be +asyncpg
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/zenithspectra

# LLM Provider: "ollama" for local dev, "groq" for production
LLM_PROVIDER=ollama

# Ollama (local dev) — tag must be pulled locally (e.g. `ollama pull gemma4:31b`)
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=gemma4:31b

# Groq (production) — MUST be a current Groq-supported model id.
# Verify at https://console.groq.com/docs/models
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# CORS (comma-separated origins) — set to your Vercel domain in prod
CORS_ORIGINS=http://localhost:3000

# Ingestion schedule (hours between RSS pulls)
INGESTION_INTERVAL_HOURS=6

# Enable LLM-powered enrichment (summaries, classification, credibility, Q&A)
ENABLE_LLM_ENRICHMENT=false

# Server
HOST=0.0.0.0
PORT=8000

# Debug mode
DEBUG=false
