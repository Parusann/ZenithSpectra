# Database (async PostgreSQL) — driver MUST be +asyncpg
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/zenithspectra

# LLM — Gemma 4 (E4B) served via Ollama (pull with: ollama pull gemma4:e4b)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=gemma4:e4b

# CORS (comma-separated origins) — set to your Vercel domain in prod
CORS_ORIGINS=http://localhost:3000

# Ingestion schedule (hours between RSS pulls)
INGESTION_INTERVAL_HOURS=6

# Enable LLM-powered enrichment (summaries, classification, credibility, Q&A)
ENABLE_LLM_ENRICHMENT=false

# Server
HOST=0.0.0.0
PORT=8000

# Debug mode
DEBUG=false
